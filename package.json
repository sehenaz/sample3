{
  "name": "mevtencia-hrms",
  "version": "1.0.0",
  "description": "MEVTENCIA HRMS System",
  "author": "Mevrick Solution Pvt Ltd",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder build --win"
  },
  "build": {
    "appId": "com.mevrick.hrms",
    "productName": "MEVTENCIA HRMS",
    "win": {
      "target": "nsis",
      "icon": "assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!node_modules/.bin"
    ]
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.4",
    "better-sqlite3": "^9.4.3"
  },
  "devDependencies": {
    "electron": "^28.3.0",
    "electron-builder": "^23.6.0"
  }
}